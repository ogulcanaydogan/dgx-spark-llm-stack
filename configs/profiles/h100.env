#!/usr/bin/env bash
# Hardware profile: NVIDIA H100 (Hopper, sm_90)
# x86_64, CUDA 12.4+, Python 3.11+
#
# Unlike DGX Spark (GB10/sm_121), H100 is a first-class citizen in all
# major ML frameworks — upstream pip wheels work without custom builds.

export HW_PROFILE="h100"
export EXPECTED_ARCH="x86_64"
export CUDA_HOME="${CUDA_HOME:-/usr/local/cuda-12.4}"
export TORCH_CUDA_ARCH_LIST="9.0"
export CUDA_COMPUTE_CAPABILITIES="9.0"

# Upstream pip wheels are sufficient — no custom build step needed.
# flash-attention, TransformerEngine, TensorRT-LLM all ship sm_90 kernels.
export INSTALL_STRATEGY="upstream-wheels"

# Compiler defaults (H100 typically runs Ubuntu 22.04 / GCC 11)
export CC="${CC:-gcc}"
export CXX="${CXX:-g++}"
