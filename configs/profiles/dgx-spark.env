#!/usr/bin/env bash
# Hardware profile: NVIDIA DGX Spark (GB10 / Blackwell, sm_121)
# ARM64, CUDA 13.0, Python 3.12

export HW_PROFILE="dgx-spark"
export EXPECTED_ARCH="aarch64"
export CUDA_HOME="${CUDA_HOME:-/usr/local/cuda-13.0}"
export TORCH_CUDA_ARCH_LIST="12.1"
export CUDA_COMPUTE_CAPABILITIES="12.1"

# Custom wheel builds required for sm_121 — install.sh handles this
export INSTALL_STRATEGY="custom-wheels"

# Compiler (GCC 13.x ships with CUDA 13.0 on DGX Spark)
export CC="${CC:-gcc-13}"
export CXX="${CXX:-g++-13}"
